# glia-test/.env.example — copy to .env and edit.
#
# Variables here are injected into the Hub container at compose-up.
# They are NEVER picked up by production environments. This overlay is
# strictly for local integration testing against the Hub.

# JWT signing secret for Hub `authorization` checks. Any non-empty
# string works for tests; production should be a 32+ byte random key.
GLIA_JWT_SECRET=glia-dev-secret-not-for-prod

# Argon2id hash of the admin password. Default below is for password
# `glia`. Regenerate with:
#   cargo run -p glia-test-hashgen -- <your-password>
# and paste the printed PHC string below.
GLIA_ADMIN_HASH=$argon2id$v=19$m=19456,t=2,p=1$B6ZwHJD6w2/lsCzFbsJB5A$K6ydJ1VIPVsPA8ZmvglA+wCqTnupT7sFK/w8H71gopc

# OpenBao root token (matches compose dev-mode root-token-id).
OPENBAO_ROOT_TOKEN=glia-root

# Reserved for future: GLIA_HELIX_TOKEN if/when helixdb is authed.
# HELIXDB_TOKEN=
