{
  "name": "glia",
  "private": true,
  "packageManager": "yarn@4.17.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A -p -t run build",
    "dev": "yarn workspaces foreach -Ap --include '@glia/*' run dev",
    "lint": "yarn workspaces foreach -A -p run lint",
    "typecheck": "yarn workspaces foreach -A -p -t run typecheck",
    "test": "yarn workspaces foreach -A -p run test",
    "dev:hub": "cargo run -p glia-hub",
    "dev:web": "yarn workspace @glia/web dev",
    "dev:all": "concurrently \"yarn dev:hub\" \"yarn dev:web\"",
    "constraints": "yarn constraints"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "turbo": "^2.9.14",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-virtual": "^3.14.4",
    "react-hook-form": "^7.80.0",
    "zod": "^4.4.3"
  }
}
